## Download the base image.
FROM registry.ocp4.example.com:8443/ubi10/nodejs-22-minimal:10.
## Set the enironment variable of port number.
ENV PORT=8080
EXPOSE ${PORT}
ADD . $HOME

RUN npm ci --omit=dev && rm -rf .npm
## Granting the root privileges to '/var/cache' directory.
USER root
RUN chgrp -R 0 /var/cache && \
    chmod -R g=u /var/cache
## Change the user ID to 1001, so that Openshift will not generate error.
USER 1001
## Start the npm service.
CMD npm start
